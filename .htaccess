# Cascarino's Pizzeria - Apache Server Configuration (.htaccess)
# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remove trailing slashes from URLs (except directories)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [L,R=301]
    
    # Redirect HTTP to HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Enable GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/xml+rss
</IfModule>

# Caching for Better Performance
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images (30 days)
    ExpiresByType image/jpeg A2592000
    ExpiresByType image/gif A2592000
    ExpiresByType image/png A2592000
    ExpiresByType image/webp A2592000
    ExpiresByType image/svg+xml A2592000
    
    # CSS and JavaScript (1 year)
    ExpiresByType text/css A31536000
    ExpiresByType application/javascript A31536000
    ExpiresByType text/javascript A31536000
    
    # HTML (24 hours)
    ExpiresByType text/html A86400
    
    # Fonts (1 year)
    ExpiresByType font/ttf A31536000
    ExpiresByType font/otf A31536000
    ExpiresByType font/woff A31536000
    ExpiresByType font/woff2 A31536000
    
    # Default
    ExpiresDefault A604800
</IfModule>

# Cache Control Headers
<IfModule mod_headers.c>
    # Cache control for static assets
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|woff|woff2|ttf|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Cache control for CSS and JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    # Cache control for HTML
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
    
    # Security Headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove server info
    Header always unset X-Powered-By
    Header unset X-Powered-By
</IfModule>

# Disable Directory Indexing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(env|json|config|php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Prevent access to hidden files
<FilesMatch "^\.|\.(?:bak|conf|dist|in|log|sh|sql|sw[op]|tar)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Block specific directories
<DirectoryMatch "^\..*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</DirectoryMatch>

# UTF-8 Encoding
AddDefaultCharset UTF-8

# Enable Large File Uploads
php_value upload_max_filesize 100M
php_value post_max_size 100M

# Custom Error Pages (uncomment if you have error pages)
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html

# Disable PHP execution in upload directories
<Directory "/uploads">
    php_flag engine off
</Directory>
